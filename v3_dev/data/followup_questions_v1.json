{
  "meta": {
    "schema_version": "v1.0",
    "module_id": "CD-V3-FOLLOWUP-QUESTIONS",
    "created": "2026-04-30",
    "purpose": "Questions de clarification ciblées par catégorie. Déclenchées si confidence < seuil OU si catégorie = general_vague. Inspiré du modèle adaptive interview Ada (version lite, sans Bayesian). Non-bloquant : patient peut skip et avoir orientation directe.",
    "philosophy": "Pas plus de 3 questions par tour. Chaque question doit être DECISIONNELLE (la réponse change l'orientation ou la category). Si réponse non disponible → orientation calculée sans cette info, avec note 'incomplete information'.",
    "trigger_conditions": {
      "activate_if_any": [
        "confidence_score < 5",
        "category == 'general_vague_non_specifique'",
        "fallback_used == true",
        "matched_expressions_count <= 1 AND no_red_flag"
      ]
    },
    "max_questions_per_round": 3,
    "max_rounds": 2,
    "language_policy": "FR patient language, simple, no medical jargon"
  },

  "questions_by_category": {

    "dermatologie_simple": [
